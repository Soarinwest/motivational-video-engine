# =========================================================================
# motive-engine: generated drafts and review-routed videos (local-only)
# =========================================================================
outputs/drafts/**
outputs/approved/**
outputs/rejected/**
outputs/voice_auditions/**
!outputs/drafts/.gitkeep
!outputs/approved/.gitkeep
!outputs/rejected/.gitkeep

# =========================================================================
# motive-engine: generated / licensed binary assets
# Keep .gitkeep so the directories survive a clone.
# =========================================================================
assets/backgrounds/**
assets/figures/**
assets/overlays/**
assets/music/**
assets/fonts/**
!assets/backgrounds/.gitkeep
!assets/figures/.gitkeep
!assets/overlays/.gitkeep
!assets/music/.gitkeep
!assets/fonts/.gitkeep

# =========================================================================
# motive-engine: planned run-state DB
# =========================================================================
motive.db
*.db-journal
*.sqlite
*.sqlite3

